# ============================================================
# BookStack RAG Agent — Environment Configuration
# ============================================================
# Copy to .env and fill in required values:
#   cp .env.example .env

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/bookstack_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5435/bookstack_rag

# --- BookStack API --- (required for ingestion)
BOOKSTACK_BASE_URL=https://your-bookstack-instance.com
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# --- LLM ---
LLM_PROVIDER=groq                   # openai | openrouter | groq | ollama
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your-api-key            # not needed for ollama
# LLM_BASE_URL=                     # auto-resolved from provider
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
# OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings (local, no API key) ---
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=bookstack_documents

# --- Retrieval ---
RETRIEVAL_MODE=hybrid                # dense | hybrid | keyword
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3
DENSE_WEIGHT=0.7
BM25_WEIGHT=0.3

# --- Reranker ---
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string
ADMIN_DEFAULT_PASSWORD=admin1234

# --- Feature toggles ---
DEBUG=false
GUARDRAILS_ENABLED=true
QUERY_REWRITER_ENABLED=true
CONTEXT_COMPRESSION_ENABLED=true
CACHE_ENABLED=true
STREAMING_ENABLED=true
MAX_CONTEXT_TOKENS=4096
MMR_LAMBDA=0.7
HALLUCINATION_THRESHOLD=0.5
MIN_SUPPORTING_CHUNKS=1

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
