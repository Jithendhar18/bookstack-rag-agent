# ============================================================
# BookStack RAG Agent — Environment Configuration Reference
# ============================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for the app to work.
# Variables marked [SECRET] should never be committed to git.

# --- App ---
APP_NAME=BookStack RAG Agent
APP_VERSION=2.0.0
DEBUG=true                          # Set false in production
ENVIRONMENT=development             # "development" or "production"

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database --- [REQUIRED] [SECRET]
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/bookstack_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5435/bookstack_rag

# --- BookStack API --- [REQUIRED for ingestion] [SECRET]
BOOKSTACK_BASE_URL=https://your-bookstack-instance.com
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# --- OpenAI --- [REQUIRED] [SECRET]
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- LLM ---
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# --- Embeddings (runs locally, no API key needed) ---
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu                # "cpu" or "cuda"

# --- Vector Store ---
VECTOR_STORE_TYPE=qdrant             # "faiss", "pgvector", or "qdrant"
FAISS_INDEX_PATH=./data/faiss_index

# --- Qdrant --- [REQUIRED when VECTOR_STORE_TYPE=qdrant]
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=bookstack_chunks
QDRANT_API_KEY=                      # Optional for local, required for Qdrant Cloud

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# --- Auth / JWT --- [REQUIRED] [SECRET]
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Admin Seed --- [SECRET]
ADMIN_DEFAULT_PASSWORD=admin1234

# --- LangSmith (optional) --- [SECRET]
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bookstack-rag-agent
LANGSMITH_TRACING_V2=true
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=bookstack-rag-agent

# --- Redis --- [REQUIRED]
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Retrieval ---
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# --- Reranker ---
RERANKER_MODEL=BAAI/bge-reranker-large
RERANKER_BATCH_SIZE=16

# --- Caching ---
CACHE_ENABLED=true
CACHE_QUERY_TTL=600
CACHE_RETRIEVAL_TTL=300

# --- Celery --- [REQUIRED for ingestion]
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Guardrails ---
GUARDRAILS_ENABLED=true
MIN_SUPPORTING_CHUNKS=1
HALLUCINATION_THRESHOLD=0.5

# --- Streaming ---
STREAMING_ENABLED=true

# --- Context Compression ---
MAX_CONTEXT_TOKENS=4096
MMR_LAMBDA=0.7
