# App
APP_NAME=BookStack RAG Agent
APP_VERSION=2.0.0
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/bookstack_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5435/bookstack_rag

# BookStack API
BOOKSTACK_BASE_URL=https://your-bookstack-instance.com
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# LLM
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# Vector store: "faiss", "pgvector", or "qdrant"
VECTOR_STORE_TYPE=qdrant
FAISS_INDEX_PATH=./data/faiss_index

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=bookstack_chunks
QDRANT_API_KEY=

# JWT
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# LangSmith
LANGSMITH_API_KEY=ls-your-langsmith-key
LANGSMITH_PROJECT=bookstack-rag-agent
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=bookstack-rag-agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Retrieval
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-large
RERANKER_BATCH_SIZE=16

# Caching
CACHE_ENABLED=true
CACHE_QUERY_TTL=600
CACHE_RETRIEVAL_TTL=300

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Guardrails
GUARDRAILS_ENABLED=true
MIN_SUPPORTING_CHUNKS=1
HALLUCINATION_THRESHOLD=0.5

# Streaming
STREAMING_ENABLED=true

# Context Compression
MAX_CONTEXT_TOKENS=4096
MMR_LAMBDA=0.7
