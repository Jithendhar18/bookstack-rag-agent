# App
APP_NAME=BookStack RAG Agent
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bookstack_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/bookstack_rag

# BookStack API
BOOKSTACK_BASE_URL=https://your-bookstack-instance.com
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# LLM
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# Embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu

# Vector store: "faiss" or "pgvector"
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./data/faiss_index

# JWT
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# LangSmith
LANGSMITH_API_KEY=ls-your-langsmith-key
LANGSMITH_PROJECT=bookstack-rag-agent
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=bookstack-rag-agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
