# ============================================================
# BookStack RAG Agent — Production Best Quality
# ============================================================
# Maximum answer quality with GPT-4o, large embeddings, and
# all pipeline stages enabled. Includes fallback for reliability.
#
# Estimated cost: ~$2-5 per 1,000 queries
# ============================================================

# --- AI Profile ---
AI_PROFILE=best

# --- LLM (GPT-4o via OpenRouter) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=openai/gpt-4o
LLM_TEMPERATURE=0.2

# --- Fallback (Groq for reliability) ---
LLM_FALLBACK_PROVIDER=groq
LLM_FALLBACK_MODEL=llama-3.1-70b-versatile
GROQ_API_KEY=gsk_your-key-here

# --- Embeddings (Large model for best accuracy) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024

# --- Retrieval (Hybrid for maximum recall) ---
RETRIEVAL_MODE=hybrid
RETRIEVAL_TOP_K=20

# --- Reranker (On — critical for quality) ---
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=8

# --- Pipeline (All stages on) ---
QUERY_REWRITER_ENABLED=true
CONTEXT_COMPRESSION_ENABLED=true
GUARDRAILS_ENABLED=true
CACHE_ENABLED=true

# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://bookstack:bookstack@postgres:5432/bookstack_rag
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=bookstack_documents

# --- BookStack ---
BOOKSTACK_BASE_URL=https://docs.example.com
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# --- Auth ---
JWT_SECRET_KEY=use-a-cryptographically-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# --- Observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=bookstack-rag-production
