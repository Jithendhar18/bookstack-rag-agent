# ============================================================
# BookStack RAG Agent — 100% Free Local Setup
# ============================================================
# Uses Ollama for LLM and local SentenceTransformers for embeddings.
# No API keys required. All processing happens on your machine.
#
# Prerequisites:
#   1. Install Ollama: https://ollama.ai
#   2. Pull model: ollama pull llama3.2
#   3. Start Ollama: ollama serve
# ============================================================

# --- AI Profile ---
AI_PROFILE=cheap

# --- LLM (Ollama) ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings (Local) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# --- Retrieval (Dense only — simpler, lower resource) ---
RETRIEVAL_MODE=dense
RETRIEVAL_TOP_K=10

# --- Reranker (Off — saves memory) ---
RERANKER_ENABLED=false

# --- Pipeline (All optional stages off) ---
QUERY_REWRITER_ENABLED=false
CONTEXT_COMPRESSION_ENABLED=false
GUARDRAILS_ENABLED=true
CACHE_ENABLED=true

# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://bookstack:bookstack@localhost:5432/bookstack_rag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=bookstack_documents

# --- BookStack ---
BOOKSTACK_BASE_URL=http://localhost:8080
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
