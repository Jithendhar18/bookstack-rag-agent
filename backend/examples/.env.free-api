# ============================================================
# BookStack RAG Agent — Free API Setup
# ============================================================
# Uses free-tier API providers. Good for testing and low traffic.
# OpenRouter offers free models; Groq has a generous free tier.
#
# Get free API keys:
#   - OpenRouter: https://openrouter.ai (free models available)
#   - Groq: https://console.groq.com (free tier)
# ============================================================

# --- LLM (OpenRouter free model) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_TEMPERATURE=0.3

# --- Fallback (Groq free tier) ---
LLM_FALLBACK_PROVIDER=groq
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_your-key-here

# --- Embeddings (Local — free) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# --- Retrieval ---
RETRIEVAL_MODE=hybrid
RETRIEVAL_TOP_K=10

# --- Reranker (Local — free) ---
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# --- Pipeline ---
QUERY_REWRITER_ENABLED=true
CONTEXT_COMPRESSION_ENABLED=true
GUARDRAILS_ENABLED=true
CACHE_ENABLED=true

# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://bookstack:bookstack@localhost:5432/bookstack_rag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=bookstack_documents

# --- BookStack ---
BOOKSTACK_BASE_URL=http://localhost:8080
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
