# ============================================================
# BookStack RAG Agent — Dense-Only Retrieval
# ============================================================
# Uses only vector similarity search (no keyword/full-text).
# Simpler and faster than hybrid, but may miss exact keyword
# matches that semantic search doesn't capture.
#
# Good for: well-written docs where semantic meaning is strong.
# ============================================================

# --- LLM ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=mistralai/mistral-small
LLM_TEMPERATURE=0.3

# --- Embeddings ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# --- Retrieval (Dense only) ---
RETRIEVAL_MODE=dense
RETRIEVAL_TOP_K=10

# --- Reranker ---
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# --- Pipeline ---
QUERY_REWRITER_ENABLED=true
CONTEXT_COMPRESSION_ENABLED=true
GUARDRAILS_ENABLED=true
CACHE_ENABLED=true

# --- Infrastructure ---
DATABASE_URL=postgresql+asyncpg://bookstack:bookstack@localhost:5432/bookstack_rag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=bookstack_documents

# --- BookStack ---
BOOKSTACK_BASE_URL=http://localhost:8080
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
